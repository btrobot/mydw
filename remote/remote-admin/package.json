{
  "name": "remote-admin",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Phase 1 protected remote admin shell with independent admin auth",
  "scripts": {
    "dev": "vite --open /index.html",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "build:react": "vite build",
    "preview:react": "vite preview --open /index.html",
    "test": "npm run build && node --test tests/react-contract.test.mjs",
    "test:react-step-up": "npm run build:react && node --test --test-concurrency=1 tests/step-up.react.test.mjs",
    "smoke:users:update:multi": "npm run build && npm run build:react && node scripts/run-smoke-users-update-multi.mjs",
    "lint": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.17.0",
    "antd": "^5.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
