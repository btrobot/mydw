[Unit]
Description=Remote auth/admin Linux deployment stack
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/mydw
ExecStart=/opt/mydw/remote/remote-shared/deploy/deploy.sh
ExecReload=/opt/mydw/remote/remote-shared/deploy/upgrade.sh
ExecStop=/usr/bin/docker compose -f /opt/mydw/remote/remote-shared/deploy/docker-compose.linux.yml down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
