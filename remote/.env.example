# Remote workspace shared environment example

# Phase 0 only freezes naming and ownership of environment variables.
# Real values and secrets are introduced in later phases.

REMOTE_ENV=development

# Backend
REMOTE_BACKEND_HOST=127.0.0.1
REMOTE_BACKEND_PORT=8100
REMOTE_BACKEND_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/remote_auth
REMOTE_BACKEND_REDIS_URL=redis://127.0.0.1:6379/0

# Admin frontend
REMOTE_ADMIN_PORT=3100
REMOTE_ADMIN_API_BASE_URL=http://127.0.0.1:8100

# Compatibility harness
REMOTE_COMPAT_BASE_URL=http://127.0.0.1:8100
