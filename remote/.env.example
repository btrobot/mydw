# Remote workspace shared environment example
#
# Copy this file to `.env` at the repository root (or export the same values in
# your shell) before running remote-backend / remote-admin in development or a
# staging-like environment.

REMOTE_ENV=development
REMOTE_STAGING_PUBLIC_BASE_URL=http://127.0.0.1:8100
REMOTE_STAGING_ADMIN_BASE_URL=http://127.0.0.1:4173
REMOTE_STAGING_PORTAL_BASE_URL=http://127.0.0.1:4174

# Backend
REMOTE_BACKEND_APP_ENV=development
REMOTE_BACKEND_HOST=127.0.0.1
REMOTE_BACKEND_PORT=8100
REMOTE_BACKEND_DATABASE_URL=sqlite:///remote/data/remote_auth.db
REMOTE_BACKEND_CORS_ALLOW_ORIGINS=http://127.0.0.1:4173,http://localhost:4173,null
# Development-only defaults. Override these in staging/prod and do not keep
# dev-style bootstrap secrets outside local environments.
REMOTE_BACKEND_ADMIN_BOOTSTRAP_USERNAME=change-me-admin
REMOTE_BACKEND_ADMIN_BOOTSTRAP_PASSWORD=change-me-bootstrap-password
REMOTE_BACKEND_MINIMUM_SUPPORTED_VERSION=0.2.0
REMOTE_BACKEND_DEFAULT_OFFLINE_GRACE_HOURS=24

# Admin frontend
REMOTE_ADMIN_PORT=4173
REMOTE_ADMIN_API_BASE_URL=http://127.0.0.1:8100

# Planned end-user portal (reserved for Complete System v1)
REMOTE_PORTAL_PORT=4174
REMOTE_PORTAL_API_BASE_URL=http://127.0.0.1:8100
REMOTE_PORTAL_PUBLIC_BASE_URL=http://127.0.0.1:4174

# Compatibility harness / release-gate smoke
REMOTE_COMPAT_BASE_URL=http://127.0.0.1:8100
REMOTE_COMPAT_USERNAME=alice
REMOTE_COMPAT_PASSWORD=secret
REMOTE_COMPAT_DEVICE_ID=device_ci
REMOTE_COMPAT_ADMIN_USERNAME=change-me-admin
REMOTE_COMPAT_ADMIN_PASSWORD=change-me-admin-password
