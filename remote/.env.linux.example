# Remote workspace Linux deployment environment example
#
# Copy this file to the repository-root `.env` on the Linux host before running:
#   remote/remote-shared/deploy/deploy.sh
# or:
#   docker compose -f remote/remote-shared/deploy/docker-compose.linux.yml up -d --build
#
# This template is server-oriented. It assumes:
# - reverse proxy traffic enters the compose stack
# - admin calls backend through /api
# - SQLite data lives on the shared /data volume unless you replace it
# - HTTPS cert files, when enabled, are mounted from:
#   remote/remote-shared/deploy/certs/fullchain.pem
#   remote/remote-shared/deploy/certs/privkey.pem

REMOTE_ENV=staging

# Deployment shell / proxy
REMOTE_DEPLOY_BRANCH=main
REMOTE_DEPLOY_TLS_MODE=http
REMOTE_DEPLOY_SERVER_NAME=remote.example.com
REMOTE_DEPLOY_HTTP_PORT=80
REMOTE_DEPLOY_HTTPS_PORT=443
REMOTE_STAGING_PUBLIC_BASE_URL=https://remote.example.com
REMOTE_STAGING_ADMIN_BASE_URL=https://remote.example.com/admin/
REMOTE_STAGING_PORTAL_BASE_URL=https://remote.example.com/

# Backend
REMOTE_BACKEND_APP_ENV=staging
REMOTE_BACKEND_HOST=0.0.0.0
REMOTE_BACKEND_PORT=8100
REMOTE_BACKEND_DATABASE_URL=sqlite:////data/remote_auth.db
REMOTE_BACKEND_LOGIN_RATE_LIMIT_BACKEND=sqlite
REMOTE_BACKEND_LOGIN_RATE_LIMIT_SQLITE_PATH=/data/login_rate_limits.sqlite3
REMOTE_BACKEND_CORS_ALLOW_ORIGINS=https://remote.example.com
REMOTE_BACKEND_ADMIN_BOOTSTRAP_USERNAME=remote-admin
REMOTE_BACKEND_ADMIN_BOOTSTRAP_PASSWORD=replace-with-strong-bootstrap-password
REMOTE_BACKEND_MINIMUM_SUPPORTED_VERSION=0.2.0
REMOTE_BACKEND_DEFAULT_OFFLINE_GRACE_HOURS=24

# Admin frontend
REMOTE_ADMIN_PORT=80
REMOTE_ADMIN_API_BASE_URL=/api

# Planned end-user portal (reserved for Complete System v1)
REMOTE_PORTAL_PORT=8080
REMOTE_PORTAL_API_BASE_URL=/api
REMOTE_PORTAL_PUBLIC_BASE_URL=https://remote.example.com/

# Compatibility harness / release-gate smoke
REMOTE_COMPAT_BASE_URL=https://remote.example.com
REMOTE_COMPAT_USERNAME=alice
REMOTE_COMPAT_PASSWORD=replace-with-compat-user-password
REMOTE_COMPAT_DEVICE_ID=device_linux_stage
REMOTE_COMPAT_ADMIN_USERNAME=remote-admin
REMOTE_COMPAT_ADMIN_PASSWORD=replace-with-compat-admin-password
