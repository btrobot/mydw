{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "name": "dewugojin",
  "version": "2.0.0",
  "description": "得物掘金工具 - 完整多Agent协作框架",

  "agents": {
    "directory": ".claude/agents",
    "enabled": [
      "project-manager",
      "tech-lead",
      "frontend-lead",
      "backend-lead",
      "qa-lead",
      "devops-engineer",
      "ui-developer",
      "api-developer",
      "automation-developer",
      "test-engineer",
      "security-expert"
    ]
  },

  "skills": {
    "directory": ".claude/skills",
    "enabled": [
      "sprint-plan",
      "task-breakdown",
      "architecture-review",
      "code-review",
      "security-scan"
    ]
  },

  "rules": {
    "enabled": true,
    "paths": [
      ".claude/rules/coordination-rules.md",
      ".claude/rules/typescript-style.md",
      ".claude/rules/python-style.md",
      ".claude/rules/security-rules.md",
      ".claude/rules/commit-rules.md"
    ]
  },

  "hooks": {
    "SessionStart": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "powershell -ExecutionPolicy Bypass -File .claude/hooks/session-start.ps1",
        "timeout": 15
      }]
    }],
    "PreToolUse": [{
      "matcher": "Write|Edit",
      "hooks": [{
        "type": "command",
        "command": "powershell -ExecutionPolicy Bypass -File .claude/hooks/pre-commit.ps1",
        "timeout": 5
      }]
    }],
    "Stop": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "powershell -ExecutionPolicy Bypass -File .claude/hooks/session-end.ps1",
        "timeout": 10
      }]
    }]
  }
}
